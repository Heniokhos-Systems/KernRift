{
  "name": "kernrift",
  "displayName": "KernRift",
  "description": "Language support for KernRift systems language (.kr files)",
  "version": "2.8.27",
  "publisher": "Pantelis23",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rift-Intelligence/KernRift"
  },
  "icon": "logo.png",
  "engines": {
    "vscode": "^1.90.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:kernrift"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kernrift",
        "aliases": [
          "KernRift",
          "kr"
        ],
        "extensions": [
          ".kr"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/kr-file.svg",
          "dark": "./icons/kr-file.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "kernrift",
        "scopeName": "source.kr",
        "path": "./syntaxes/kernrift.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "KernRift",
      "properties": {
        "kernrift.compilerPath": {
          "type": "string",
          "default": "krc",
          "description": "Path to the krc compiler binary"
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.3"
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node && esbuild src/server.ts --bundle --outfile=out/server.js --format=cjs --platform=node",
    "package": "npx vsce package"
  }
}
