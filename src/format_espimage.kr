// format_espimage.kr — esp-image container writer for --target=esp32.
//
// Writes the flash image format the ESP32 boot ROM loads directly (design
// doc: docs/superpowers/specs/2026-07-20-esp32-machine-target-design.md §1,
// hardware-confirmed 2026-07-20). Mirrors the role codegen_xtensa.kr's
// Elf32 writer plays for the qemu lx60 target — but into its OWN buffer
// (esp_image_buf), not codegen's out_buf, because the segment payloads
// handed to esp_image_segment() typically point INTO out_buf.
//
// Byte-exactness gate: tests/run_tests.sh `esp32_image_format` compares the
// output of this file byte-for-byte against tests/golden/esp32_ref_image.bin,
// generated by `esptool --chip esp32 elf2image --flash-mode dio
// --flash-freq 40m --flash-size 4MB` (esptool v5.3.1). A wrong byte here is
// a chip that silently refuses to boot — do not touch any field without
// re-running that test.
//
// Format cheat sheet (all multi-byte fields little-endian):
//   0x00  1  magic            0xE9
//   0x01  1  segment_count
//   0x02  1  spi_mode         0x02 = DIO        <- ROM-validated; board-confirmed
//   0x03  1  spi_size<<4|freq 0x20 = 4MB @ 40M  <- ROM-validated; board-confirmed
//   0x04  4  entry_addr
//   0x08  1  wp_pin           0xEE (disabled)
//   0x09  3  spi_pin_drv      0,0,0
//   0x0C  2  chip_id          0 (ESP32)
//   0x0E  1  min_chip_rev     0
//   0x0F  2  min_chip_rev_full 0
//   0x11  2  max_chip_rev_full 0xFFFF
//   0x13  4  reserved         0
//   0x17  1  hash_appended    1
//   0x18.. segments: [load_addr u32][data_len u32][payload], data_len padded
//          to a multiple of 4 with zero bytes (pad bytes are part of the
//          payload for checksum purposes).
//   then:  zero-pad the file until len % 16 == 15, append the checksum byte
//          (seed 0xEF, XOR of every segment payload byte ONLY — not the
//          headers, not the load_addr/len words), then the SHA-256 of the
//          entire file through the checksum byte, 32 raw bytes.
//
// The SHA-256 comes from std/sha256.kr (host-only u64 code — fine: the image
// is produced at COMPILE time on the host; nothing hashes on the ESP32).
// Build wiring: both files ride in SRCS in the Makefile; standalone users
// (the test harness) import "std/sha256.kr" + "src/format_espimage.kr".
//
// Task 3 (main.kr esp32 wiring) drives it like this:
//   esp_image_begin(entry, 2)
//   esp_image_segment(0x3FFB0000, dram_ptr, dram_len)   // ascending addr
//   esp_image_segment(0x40080400, iram_ptr, iram_len)   //   order, like
//   esp_image_finish()                                  //   esptool
//   write(fd, esp_image_buf, esp_image_len)
//
// NOTE on segment order: esptool emits segments sorted ascending by load
// address (DRAM 0x3FFB_0000 before IRAM 0x4008_0400) and the golden was
// generated that way. The ROM itself doesn't care, but byte-comparability
// with esptool does — callers should keep that order.

static uint64 esp_image_buf = 0
static uint64 esp_image_len = 0
static uint64 esp_image_cap = 0

// Running XOR checksum (seed 0xEF) over segment payload bytes only.
static uint64 esp_image_checksum = 0
// Declared vs actually-written segment count: the count is a header byte
// written up front, so a mismatch would ship a corrupt image. Loud-fail.
static uint64 esp_image_seg_declared = 0
static uint64 esp_image_seg_written = 0
static uint64 esp_image_finished = 0

fn esp_image_fail(uint64 msg) {
    uint64 pre = "error: esp-image: "
    write(2, pre, str_len(pre))
    write(2, msg, str_len(msg))
    write(2, "\n", 1)
    exit(1)
}

// Append one byte, growing the buffer geometrically (same discipline as
// codegen.kr's emit_byte — alloc/memcpy/dealloc, doubling cap).
fn espimg_byte(uint64 v) {
    if esp_image_len >= esp_image_cap {
        uint64 new_cap = esp_image_cap * 2
        if new_cap < 4096 { new_cap = 4096 }
        uint64 new_buf = alloc(new_cap)
        memcpy(new_buf, esp_image_buf, esp_image_len)
        if esp_image_buf != 0 { dealloc(esp_image_buf) }
        esp_image_buf = new_buf
        esp_image_cap = new_cap
    }
    uint64 p = esp_image_buf + esp_image_len
    uint8 b = v & 0xFF
    unsafe { *(p as uint8) = b }
    esp_image_len = esp_image_len + 1
}

fn espimg_u32_le(uint64 v) {
    espimg_byte(v & 0xFF)
    espimg_byte((v >> 8) & 0xFF)
    espimg_byte((v >> 16) & 0xFF)
    espimg_byte((v >> 24) & 0xFF)
}

// Start a new image: reset all state and emit the 24-byte header
// (8-byte main header + 16-byte extended header).
fn esp_image_begin(uint64 entry_addr, uint64 seg_count) {
    if seg_count == 0 { esp_image_fail("segment count must be >= 1") }
    if seg_count > 16 { esp_image_fail("more than 16 segments (IDF cap)") }

    if esp_image_buf != 0 {
        dealloc(esp_image_buf)
        esp_image_buf = 0
    }
    esp_image_len = 0
    esp_image_cap = 0
    esp_image_checksum = 0xEF
    esp_image_seg_declared = seg_count
    esp_image_seg_written = 0
    esp_image_finished = 0

    // Main header — 8 bytes @ 0x00.
    espimg_byte(0xE9)             // magic
    espimg_byte(seg_count)        // segment_count
    espimg_byte(0x02)             // spi_mode = DIO       (ROM-validated)
    espimg_byte(0x20)             // 4 MB << 4 | 40 MHz   (ROM-validated)
    espimg_u32_le(entry_addr)     // entry point

    // Extended header — 16 bytes @ 0x08.
    espimg_byte(0xEE)             // wp_pin = disabled
    espimg_byte(0)                // spi_pin_drv[0]
    espimg_byte(0)                // spi_pin_drv[1]
    espimg_byte(0)                // spi_pin_drv[2]
    espimg_byte(0)                // chip_id lo (0 = ESP32)
    espimg_byte(0)                // chip_id hi
    espimg_byte(0)                // min_chip_rev (legacy)
    espimg_byte(0)                // min_chip_rev_full lo
    espimg_byte(0)                // min_chip_rev_full hi
    espimg_byte(0xFF)             // max_chip_rev_full lo  (0xFFFF = any)
    espimg_byte(0xFF)             // max_chip_rev_full hi
    espimg_byte(0)                // reserved[0]
    espimg_byte(0)                // reserved[1]
    espimg_byte(0)                // reserved[2]
    espimg_byte(0)                // reserved[3]
    espimg_byte(1)                // hash_appended = 1
}

// Append one segment: [load_addr][data_len][payload], with data_len padded
// up to a multiple of 4 by zero bytes. `len` is the RAW payload length —
// padding happens here. Every payload byte (pad included — a no-op, since
// x XOR 0 == x, but stated for clarity) enters the running checksum; the
// load_addr/data_len words do NOT.
fn esp_image_segment(uint64 load_addr, uint64 data_ptr, uint64 len) {
    if esp_image_buf == 0 { esp_image_fail("segment before esp_image_begin") }
    if esp_image_finished != 0 { esp_image_fail("segment after esp_image_finish") }
    if esp_image_seg_written >= esp_image_seg_declared {
        esp_image_fail("more segments than declared in esp_image_begin")
    }

    uint64 padded = (len + 3) & 0xFFFFFFFFFFFFFFFC
    espimg_u32_le(load_addr)
    espimg_u32_le(padded)

    uint64 i = 0
    while i < len {
        uint64 b = load8(data_ptr + i)
        esp_image_checksum = (esp_image_checksum ^ b) & 0xFF
        espimg_byte(b)
        i = i + 1
    }
    while i < padded {
        espimg_byte(0)
        i = i + 1
    }

    esp_image_seg_written = esp_image_seg_written + 1
}

// Finish the image: pad to len % 16 == 15, append the checksum byte (the
// image through the checksum is then 16-byte aligned), then append the
// SHA-256 of everything so far (32 raw bytes). After this the image is
// complete in esp_image_buf[0 .. esp_image_len).
fn esp_image_finish() {
    if esp_image_buf == 0 { esp_image_fail("finish before esp_image_begin") }
    if esp_image_finished != 0 { esp_image_fail("finish called twice") }
    if esp_image_seg_written != esp_image_seg_declared {
        esp_image_fail("fewer segments written than declared in esp_image_begin")
    }

    while (esp_image_len % 16) != 15 {
        espimg_byte(0)
    }
    espimg_byte(esp_image_checksum)

    // SHA-256 over the entire file through the checksum byte. Digest is
    // captured into a scratch buffer BEFORE appending, since appending can
    // grow (realloc) esp_image_buf.
    uint64 ctx = alloc(SHA256_CTX_SIZE)
    uint64 digest = alloc(32)
    sha256_init(ctx)
    sha256_update(ctx, esp_image_buf, esp_image_len)
    sha256_final(ctx, digest)
    uint64 i = 0
    while i < 32 {
        espimg_byte(load8(digest + i))
        i = i + 1
    }
    dealloc(digest)
    dealloc(ctx)

    esp_image_finished = 1
}
